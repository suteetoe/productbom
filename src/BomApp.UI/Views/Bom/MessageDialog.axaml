<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="BomApp.UI.Views.Bom.MessageDialog"
        Width="380" Height="180"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{StaticResource SurfaceBrush}">

    <Grid RowDefinitions="Auto,*,Auto" Margin="24,20,24,20">

        <TextBlock x:Name="TitleText"
                   Grid.Row="0"
                   FontSize="{StaticResource FontSizeBase}"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimaryBrush}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,10"/>

        <TextBlock x:Name="MessageText"
                   Grid.Row="1"
                   FontSize="{StaticResource FontSizeBase}"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   TextWrapping="Wrap"
                   VerticalAlignment="Top"/>

        <Button Grid.Row="2"
                Content="OK"
                HorizontalAlignment="Right"
                HorizontalContentAlignment="Center"
                MinWidth="88"
                FontSize="{StaticResource FontSizeBase}"
                CornerRadius="{StaticResource RadiusMD}"
                Padding="16,6"
                Background="{StaticResource AccentBlueBrush}"
                Foreground="White"
                Click="OnOkClick"/>

    </Grid>
</Window>
