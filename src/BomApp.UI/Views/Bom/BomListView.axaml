<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BomApp.UI.ViewModels.Bom"
             xmlns:conv="using:BomApp.UI.Converters"
             xmlns:contracts="using:BomApp.Shared.Contracts"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="BomApp.UI.Views.Bom.BomListView"
             x:DataType="vm:BomListViewModel">

    <UserControl.Resources>
        <conv:BomStatusToBrushConverter x:Key="StatusToBrush"/>
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,Auto,*,Auto">
        <Border Grid.Row="0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="{StaticResource PanelPadding}"
                Height="{StaticResource ToolbarHeight}">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0"
                           Text="สูตรการผลิต"
                           FontSize="{StaticResource FontSizeH2}"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="1"
                        Content="+ สร้างสูตรใหม่"
                        Command="{Binding CreateNewCommand}"
                        Background="{StaticResource AccentBlueBrush}"
                        Foreground="White"
                        FontSize="{StaticResource FontSizeBase}"
                        CornerRadius="{StaticResource RadiusMD}"
                        Padding="{StaticResource SpaceSM}"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <StackPanel Grid.Row="1"
                    Margin="{StaticResource PanelPadding}"
                    Spacing="8">
            <Grid ColumnDefinitions="*,Auto,120" ColumnSpacing="8">
                <TextBox Grid.Column="0"
                         Text="{Binding SearchText, Mode=TwoWay}"
                         PlaceholderText="ค้นหา รหัส / ชื่อสูตร"
                         FontSize="{StaticResource FontSizeBase}"
                         CornerRadius="{StaticResource RadiusMD}"/>

                <TextBlock Grid.Column="1"
                           Text="ต่อหน้า"
                           FontSize="{StaticResource FontSizeSM}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>

                <ComboBox Grid.Column="2"
                          ItemsSource="{Binding PageSizeOptions}"
                          SelectedItem="{Binding PageSize, Mode=TwoWay}"
                          FontSize="{StaticResource FontSizeBase}"
                          CornerRadius="{StaticResource RadiusMD}"/>
            </Grid>

            <Border Background="#FEF2F2"
                    BorderBrush="{StaticResource DangerBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource RadiusSM}"
                    Padding="{StaticResource SpaceSM}"
                    IsVisible="{Binding HasError}">
                <TextBlock Text="{Binding ErrorMessage}"
                           FontSize="{StaticResource FontSizeSM}"
                           Foreground="{StaticResource DangerBrush}"
                           TextWrapping="Wrap"/>
            </Border>
        </StackPanel>

        <Grid Grid.Row="2" Margin="{StaticResource SpaceLG}">
            <Border BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource RadiusSM}"
                    Background="{StaticResource SurfaceBrush}">
                <DockPanel LastChildFill="True">
                    <Border DockPanel.Dock="Top"
                            Background="{StaticResource SurfaceSecondaryBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="8,6">
                        <Grid ColumnDefinitions="120,*,140,70,100,120,220" ColumnSpacing="8">
                            <TextBlock Grid.Column="0" Text="รหัสสูตร" FontSize="{StaticResource FontSizeSM}" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="ชื่อสูตร" FontSize="{StaticResource FontSizeSM}" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="2" Text="สินค้า" FontSize="{StaticResource FontSizeSM}" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="3" Text="เวอร์ชัน" FontSize="{StaticResource FontSizeSM}" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="4" Text="สถานะ" FontSize="{StaticResource FontSizeSM}" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="5" Text="แก้ไขล่าสุด" FontSize="{StaticResource FontSizeSM}" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </Grid>
                    </Border>

                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Items}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="contracts:BomDto">
                                    <Border BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="0,0,0,1"
                                            Padding="8,5"
                                            MinHeight="{StaticResource DataGridRowHeight}">
                                        <Grid ColumnDefinitions="120,*,140,70,100,120,220" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Text="{Binding Code}" FontSize="{StaticResource FontSizeBase}" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="{StaticResource FontSizeBase}" Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="{Binding ItemCode}" FontSize="{StaticResource FontSizeBase}" Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="3" Text="{Binding Version}" FontSize="{StaticResource FontSizeBase}" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="4" Text="{Binding Status}" FontSize="{StaticResource FontSizeSM}" FontWeight="SemiBold" Foreground="{Binding Status, Converter={StaticResource StatusToBrush}}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="5" Text="{Binding UpdatedAt, StringFormat='{}{0:dd/MM/yyyy}'}" FontSize="{StaticResource FontSizeBase}" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="6" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                                <Button Content="แก้ไข" FontSize="{StaticResource FontSizeSM}" Padding="6,2" CornerRadius="{StaticResource RadiusSM}" Command="{Binding ((vm:BomListViewModel)DataContext).EditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>
                                                <Button Content="เปิดใช้งาน" FontSize="{StaticResource FontSizeSM}" Padding="6,2" CornerRadius="{StaticResource RadiusSM}" Foreground="{StaticResource SuccessBrush}" Command="{Binding ((vm:BomListViewModel)DataContext).ActivateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>
                                                <Button Content="ปิดใช้งาน" FontSize="{StaticResource FontSizeSM}" Padding="6,2" CornerRadius="{StaticResource RadiusSM}" Foreground="{StaticResource WarningBrush}" Command="{Binding ((vm:BomListViewModel)DataContext).DeactivateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>
                                                <Button Content="ลบ" FontSize="{StaticResource FontSizeSM}" Padding="6,2" CornerRadius="{StaticResource RadiusSM}" Foreground="{StaticResource DangerBrush}" Command="{Binding ((vm:BomListViewModel)DataContext).DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                IsVisible="{Binding IsLoading}"
                Background="#B3FFFFFF">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8">
                <ProgressBar IsIndeterminate="True"
                             Width="160"
                             Height="4"
                             Foreground="{StaticResource AccentBlueBrush}"/>
                <TextBlock Text="กำลังโหลด..."
                           FontSize="{StaticResource FontSizeSM}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="3"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="{StaticResource SpaceSM}">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0"
                           Text="{Binding PageSummary}"
                           FontSize="{StaticResource FontSizeSM}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="8">
                    <Button Content="ก่อนหน้า"
                            Command="{Binding PreviousPageCommand}"
                            IsEnabled="{Binding CanGoPrevious}"
                            FontSize="{StaticResource FontSizeSM}"
                            CornerRadius="{StaticResource RadiusSM}"
                            Padding="10,4"/>
                    <Button Content="ถัดไป"
                            Command="{Binding NextPageCommand}"
                            IsEnabled="{Binding CanGoNext}"
                            FontSize="{StaticResource FontSizeSM}"
                            CornerRadius="{StaticResource RadiusSM}"
                            Padding="10,4"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
