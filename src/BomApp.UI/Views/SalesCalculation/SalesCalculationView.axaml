<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BomApp.UI.ViewModels.SalesCalculation"
             xmlns:contracts="using:BomApp.Shared.Contracts"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="BomApp.UI.Views.SalesCalculation.SalesCalculationView"
             x:DataType="vm:SalesCalculationViewModel">

    <!--
        Layout:
          Row 0 — Toolbar "คำนวณจากการขาย"                          [Auto]
          Row 1 — Section 1: date pickers + options + Load button    [Auto]
          Row 2 — Section 2: sales table                             [*]
          Row 3 — Section 3: material result + save mode + actions   [Auto]
          Loading overlay spans all 4 rows.

        Key bindings:
          DateFrom               → Section 1 DatePicker (TwoWay)
          DateTo                 → Section 1 DatePicker (TwoWay)
          ShowOnlyWithBom        → CheckBox.IsChecked (TwoWay)
          LoadSalesCommand       → "โหลดรายการขาย" button
          HasWarning             → warning badge IsVisible
          ItemsWithoutBomCount   → warning badge text
          IsDaily                → RadioButton.IsChecked (TwoWay)
          SalesTransactions      → Section 2 table ItemsSource
          CalculateCommand       → "คำนวณ" button
          MaterialRequirements   → Section 3 table ItemsSource
          HasCalculationResult   → Save button IsEnabled
          SaveDocumentsCommand   → "บันทึกเอกสาร" button
          ExportCsvCommand       → "Export CSV" button
    -->

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- ============================================================ -->
        <!-- Row 0 — Toolbar                                               -->
        <!-- ============================================================ -->
        <Border Grid.Row="0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="{StaticResource PanelPadding}"
                Height="{StaticResource ToolbarHeight}">
            <TextBlock Text="คำนวณจากการขาย"
                       FontSize="{StaticResource FontSizeH2}"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       VerticalAlignment="Center"/>
        </Border>

        <!-- ============================================================ -->
        <!-- Row 1 — Section 1: Date filter + options + Load              -->
        <!-- ============================================================ -->
        <Border Grid.Row="1"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="{StaticResource PanelPadding}">

            <WrapPanel Orientation="Horizontal">

                <!-- วันที่เริ่มต้น -->
                <StackPanel Orientation="Horizontal" Spacing="4" Margin="{StaticResource SpaceSM}">
                    <TextBlock Text="จาก"
                               FontSize="{StaticResource FontSizeBase}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <DatePicker SelectedDate="{Binding DateFrom, Mode=TwoWay}"/>
                </StackPanel>

                <!-- ถึงวันที่ -->
                <StackPanel Orientation="Horizontal" Spacing="4" Margin="{StaticResource SpaceSM}">
                    <TextBlock Text="ถึง"
                               FontSize="{StaticResource FontSizeBase}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <DatePicker SelectedDate="{Binding DateTo, Mode=TwoWay}"/>
                </StackPanel>

                <!-- แสดงเฉพาะสินค้าที่มี BOM -->
                <CheckBox Content="แสดงเฉพาะสินค้าที่มี BOM"
                          IsChecked="{Binding ShowOnlyWithBom, Mode=TwoWay}"
                          FontSize="{StaticResource FontSizeBase}"
                          Foreground="{StaticResource TextSecondaryBrush}"
                          VerticalAlignment="Center"
                          Margin="{StaticResource SpaceSM}"/>

                <!-- โหลดรายการขาย -->
                <Button Content="โหลดรายการขาย"
                        Command="{Binding LoadSalesCommand}"
                        Background="{StaticResource AccentBlueBrush}"
                        Foreground="White"
                        FontSize="{StaticResource FontSizeBase}"
                        CornerRadius="{StaticResource RadiusMD}"
                        Padding="{StaticResource SpaceSM}"
                        Margin="{StaticResource SpaceSM}"
                        VerticalAlignment="Center"/>

                <!--
                    Warning pill: shown when ItemsWithoutBomCount > 0 (HasWarning=true).
                    Binding: ItemsWithoutBomCount → Run text
                -->
                <Border Background="#FEF3C7"
                        CornerRadius="{StaticResource RadiusMD}"
                        Padding="8,4,8,4"
                        Margin="{StaticResource SpaceSM}"
                        VerticalAlignment="Center"
                        IsVisible="{Binding HasWarning}">
                    <TextBlock FontSize="{StaticResource FontSizeSM}"
                               Foreground="{StaticResource WarningBrush}">
                        <Run Text="{Binding ItemsWithoutBomCount}"/>
                        <Run Text=" รายการไม่มีสูตรการผลิต"/>
                    </TextBlock>
                </Border>

            </WrapPanel>
        </Border>

        <!-- ============================================================ -->
        <!-- Row 2 — Section 2: Sales transactions table                   -->
        <!-- ============================================================ -->
        <Border Grid.Row="2"
                Margin="{StaticResource SpaceLG}"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource RadiusMD}"
                Padding="{StaticResource SpaceSM}">

            <Grid RowDefinitions="Auto,*">

                <TextBlock Grid.Row="0"
                           Text="รายการขาย"
                           FontSize="{StaticResource FontSizeLG}"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           Margin="{StaticResource SpaceSM}"/>

                <Border Grid.Row="1"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource RadiusSM}"
                        Background="{StaticResource SurfaceBrush}">
                    <DockPanel LastChildFill="True">
                        <Border DockPanel.Dock="Top"
                                Background="{StaticResource SurfaceSecondaryBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="8,6">
                            <Grid ColumnDefinitions="140,100,120,*,90,80,120" ColumnSpacing="8">
                                <TextBlock Grid.Column="0" Text="เลขที่เอกสาร" FontSize="{StaticResource FontSizeSM}" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Column="1" Text="วันที่" FontSize="{StaticResource FontSizeSM}" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Column="2" Text="รหัสสินค้า" FontSize="{StaticResource FontSizeSM}" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Column="3" Text="ชื่อสินค้า" FontSize="{StaticResource FontSizeSM}" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Column="4" Text="จำนวน" FontSize="{StaticResource FontSizeSM}" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Column="5" Text="หน่วย" FontSize="{StaticResource FontSizeSM}" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Column="6" Text="จำนวนหน่วยหลัก" FontSize="{StaticResource FontSizeSM}" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </Grid>
                        </Border>

                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding SalesTransactions}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="contracts:ErpSalesTransactionDto">
                                        <Border BorderBrush="{StaticResource BorderBrush}"
                                                BorderThickness="0,0,0,1"
                                                Padding="8,5"
                                                MinHeight="{StaticResource DataGridRowHeight}">
                                            <Grid ColumnDefinitions="140,100,120,*,90,80,120" ColumnSpacing="8">
                                                <TextBlock Grid.Column="0" Text="{Binding DocNo}" FontSize="{StaticResource FontSizeBase}" Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="{Binding DocDate, StringFormat='{}{0:dd/MM/yyyy}'}" FontSize="{StaticResource FontSizeBase}" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="2" Text="{Binding ItemCode}" FontSize="{StaticResource FontSizeBase}" Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="3" Text="{Binding ItemName}" FontSize="{StaticResource FontSizeBase}" Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="4" Text="{Binding Qty, StringFormat='{}{0:N2}'}" FontSize="{StaticResource FontSizeBase}" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="5" Text="{Binding UnitCode}" FontSize="{StaticResource FontSizeBase}" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="6" Text="{Binding QtyInBaseUnit, StringFormat='{}{0:N4}'}" FontSize="{StaticResource FontSizeBase}" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ============================================================ -->
        <!-- Row 3 — Section 3: Material requirements + save options       -->
        <!-- ============================================================ -->
        <Border Grid.Row="3"
                Margin="{StaticResource SpaceLG}"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource RadiusMD}"
                Padding="{StaticResource SpaceSM}">

            <Grid ColumnDefinitions="*,Auto">

                <!-- Left: material requirements table -->
                <Grid Grid.Column="0" RowDefinitions="Auto,*">

                    <TextBlock Grid.Row="0"
                               Text="วัตถุดิบที่ต้องตัดเบิก"
                               FontSize="{StaticResource FontSizeLG}"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="{StaticResource SpaceSM}"/>

                    <Border Grid.Row="1"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource RadiusSM}"
                            Background="{StaticResource SurfaceBrush}"
                            Height="180">
                        <DockPanel LastChildFill="True">
                            <Border DockPanel.Dock="Top"
                                    Background="{StaticResource SurfaceSecondaryBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="0,0,0,1"
                                    Padding="8,6">
                                <Grid ColumnDefinitions="130,*,120,80" ColumnSpacing="8">
                                    <TextBlock Grid.Column="0" Text="รหัสวัตถุดิบ" FontSize="{StaticResource FontSizeSM}" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="1" Text="ชื่อวัตถุดิบ" FontSize="{StaticResource FontSizeSM}" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="2" Text="จำนวนที่ต้องการ" FontSize="{StaticResource FontSizeSM}" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="3" Text="หน่วย" FontSize="{StaticResource FontSizeSM}" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </Grid>
                            </Border>

                            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding MaterialRequirements}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="contracts:MaterialRequirementDto">
                                            <Border BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="0,0,0,1"
                                                    Padding="8,5"
                                                    MinHeight="{StaticResource DataGridRowHeight}">
                                                <Grid ColumnDefinitions="130,*,120,80" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Text="{Binding MaterialCode}" FontSize="{StaticResource FontSizeBase}" Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding MaterialName}" FontSize="{StaticResource FontSizeBase}" Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding RequiredQty, StringFormat='{}{0:N2}'}" FontSize="{StaticResource FontSizeBase}" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="3" Text="{Binding Unit}" FontSize="{StaticResource FontSizeBase}" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                </Grid>

                <!-- Right: save mode radio + action buttons -->
                <StackPanel Grid.Column="1"
                            Width="220"
                            Margin="{StaticResource SpaceLG}"
                            Spacing="12"
                            VerticalAlignment="Top">

                    <TextBlock Text="รูปแบบบันทึกเอกสาร"
                               FontSize="{StaticResource FontSizeBase}"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>

                    <!--
                        Radio buttons for SaveMode.
                        IsDaily=true  → SaveMode.Daily (รวมเป็น 1 เอกสารต่อ 1 วัน)
                        IsDaily=false → SaveMode.PerDocument (แยกตามเลขที่เอกสารขาย)
                    -->
                    <RadioButton Content="รวมเป็น 1 เอกสารต่อ 1 วัน"
                                 IsChecked="{Binding IsDaily, Mode=TwoWay}"
                                 FontSize="{StaticResource FontSizeBase}"
                                 Foreground="{StaticResource TextSecondaryBrush}"/>

                    <RadioButton Content="แยกตามเลขที่เอกสารขาย"
                                 IsChecked="{Binding IsPerDocument, Mode=TwoWay}"
                                 FontSize="{StaticResource FontSizeBase}"
                                 Foreground="{StaticResource TextSecondaryBrush}"/>

                    <!-- คำนวณ -->
                    <Button Content="คำนวณ"
                            Command="{Binding CalculateCommand}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Background="{StaticResource AccentBlueBrush}"
                            Foreground="White"
                            FontSize="{StaticResource FontSizeBase}"
                            CornerRadius="{StaticResource RadiusMD}"
                            Padding="{StaticResource SpaceSM}"/>

                    <!--
                        บันทึกเอกสาร — enabled only when HasCalculationResult=true.
                        IsEnabled binds to HasCalculationResult; CanExecute also guards via [RelayCommand].
                    -->
                    <Button Content="บันทึกเอกสาร"
                            Command="{Binding SaveDocumentsCommand}"
                            IsEnabled="{Binding HasCalculationResult}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Background="{StaticResource SuccessBrush}"
                            Foreground="White"
                            FontSize="{StaticResource FontSizeBase}"
                            CornerRadius="{StaticResource RadiusMD}"
                            Padding="{StaticResource SpaceSM}"/>

                    <!-- Export CSV -->
                    <Button Content="Export CSV"
                            Command="{Binding ExportCsvCommand}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Background="Transparent"
                            Foreground="{StaticResource AccentBlueBrush}"
                            BorderBrush="{StaticResource AccentBlueBrush}"
                            BorderThickness="1"
                            FontSize="{StaticResource FontSizeBase}"
                            CornerRadius="{StaticResource RadiusMD}"
                            Padding="{StaticResource SpaceSM}"/>

                </StackPanel>
            </Grid>
        </Border>

        <!-- ============================================================ -->
        <!-- Loading overlay — spans all 4 rows                            -->
        <!-- ============================================================ -->
        <Border Grid.Row="0" Grid.RowSpan="4"
                IsVisible="{Binding IsLoading}"
                Background="#B3FFFFFF">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8">
                <ProgressBar IsIndeterminate="True"
                             Width="160"
                             Height="4"
                             Foreground="{StaticResource AccentBlueBrush}"/>
                <TextBlock Text="กำลังโหลด..."
                           FontSize="{StaticResource FontSizeSM}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

    </Grid>
</UserControl>
