<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BomApp.UI.ViewModels.Production"
             x:Class="BomApp.UI.Views.Production.ProductionListView"
             x:DataType="vm:ProductionListViewModel">

    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto">

        <Border Grid.Row="0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="{StaticResource PanelPadding}"
                Height="{StaticResource ToolbarHeight}">
            <TextBlock Text="รายการผลิต"
                       FontSize="{StaticResource FontSizeH2}"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       VerticalAlignment="Center"/>
        </Border>

        <Border Grid.Row="1"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="{StaticResource PanelPadding}">
            <WrapPanel Orientation="Horizontal">
                <StackPanel Orientation="Horizontal" Spacing="4" Margin="{StaticResource SpaceSM}">
                    <TextBlock Text="จาก"
                               FontSize="{StaticResource FontSizeBase}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <DatePicker SelectedDate="{Binding DateFrom, Mode=TwoWay}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="4" Margin="{StaticResource SpaceSM}">
                    <TextBlock Text="ถึง"
                               FontSize="{StaticResource FontSizeBase}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <DatePicker SelectedDate="{Binding DateTo, Mode=TwoWay}"/>
                </StackPanel>

                <TextBox Text="{Binding DocNoSearch, Mode=TwoWay}"
                         PlaceholderText="เลขที่เอกสาร"
                         Width="170"
                         Margin="{StaticResource SpaceSM}"
                         CornerRadius="{StaticResource RadiusMD}"
                         FontSize="{StaticResource FontSizeBase}"/>

                <TextBox Text="{Binding ItemSearch, Mode=TwoWay}"
                         PlaceholderText="รหัสสินค้า"
                         Width="140"
                         Margin="{StaticResource SpaceSM}"
                         CornerRadius="{StaticResource RadiusMD}"
                         FontSize="{StaticResource FontSizeBase}"/>

                <Button Content="ค้นหา"
                        Command="{Binding SearchCommand}"
                        Background="{StaticResource AccentBlueBrush}"
                        Foreground="White"
                        FontSize="{StaticResource FontSizeBase}"
                        CornerRadius="{StaticResource RadiusMD}"
                        Padding="{StaticResource SpaceSM}"
                        Margin="{StaticResource SpaceSM}"
                        VerticalAlignment="Center"/>
            </WrapPanel>
        </Border>

        <Border Grid.Row="2"
                Background="#FEF2F2"
                BorderBrush="{StaticResource DangerBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource RadiusSM}"
                Padding="{StaticResource SpaceSM}"
                Margin="{StaticResource SpaceLG}"
                IsVisible="{Binding HasError}">
            <TextBlock Text="{Binding ErrorMessage}"
                       FontSize="{StaticResource FontSizeSM}"
                       Foreground="{StaticResource DangerBrush}"
                       TextWrapping="Wrap"/>
        </Border>

        <Grid Grid.Row="3" Margin="{StaticResource SpaceLG}">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8"
                        IsVisible="{Binding !HasDocuments}">
                <TextBlock Text="ยังไม่มีรายการผลิต"
                           FontSize="{StaticResource FontSizeXL}"
                           Foreground="{StaticResource TextMutedBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="ยังไม่พบเอกสารตามตัวกรองปัจจุบัน"
                           FontSize="{StaticResource FontSizeBase}"
                           Foreground="{StaticResource TextMutedBrush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <DataGrid ItemsSource="{Binding Documents}"
                      SelectedItem="{Binding SelectedDocument, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      CanUserSortColumns="True"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      RowHeight="{StaticResource DataGridRowHeight}"
                      GridLinesVisibility="Horizontal"
                      BorderBrush="{StaticResource BorderBrush}"
                      BorderThickness="1"
                      CornerRadius="{StaticResource RadiusSM}"
                      FontSize="{StaticResource FontSizeBase}"
                      Background="{StaticResource SurfaceBrush}"
                      IsVisible="{Binding HasDocuments}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="เลขที่เอกสาร"
                                        Binding="{Binding DocNo}"
                                        Width="180"/>

                    <DataGridTextColumn Header="วันที่เอกสาร"
                                        Binding="{Binding DocDate, StringFormat='{}{0:dd/MM/yyyy}'}"
                                        Width="130"/>

                    <DataGridTextColumn Header="เวลา"
                                        Binding="{Binding DocTime}"
                                        Width="100"/>

                    <DataGridTextColumn Header="จำนวนรายการ"
                                        Binding="{Binding Details.Count}"
                                        Width="110"/>

                    <DataGridTemplateColumn Header="" Width="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal"
                                            Spacing="4"
                                            VerticalAlignment="Center">
                                    <Button Content="Export"
                                            FontSize="{StaticResource FontSizeSM}"
                                            Padding="6,2"
                                            CornerRadius="{StaticResource RadiusSM}"
                                            Foreground="{StaticResource AccentBlueBrush}"
                                            Command="{Binding $parent[UserControl].((vm:ProductionListViewModel)DataContext).ExportCsvCommand}"
                                            CommandParameter="{Binding}"/>

                                    <Button Content="ลบ"
                                            FontSize="{StaticResource FontSizeSM}"
                                            Padding="6,2"
                                            CornerRadius="{StaticResource RadiusSM}"
                                            Foreground="{StaticResource DangerBrush}"
                                            Command="{Binding $parent[UserControl].((vm:ProductionListViewModel)DataContext).DeleteDocumentCommand}"
                                            CommandParameter="{Binding}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <Border Grid.Row="4"
                Margin="{StaticResource SpaceLG}"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource RadiusMD}"
                MaxHeight="220"
                IsVisible="{Binding SelectedDocument, Converter={x:Static ObjectConverters.IsNotNull}}">
            <Grid RowDefinitions="Auto,*">
                <TextBlock Grid.Row="0"
                           Text="รายละเอียดสินค้าที่ต้องผลิต"
                           FontSize="{StaticResource FontSizeSM}"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="{StaticResource SpaceSM}"/>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding SelectedDocumentDetails}"
                          AutoGenerateColumns="False"
                          CanUserSortColumns="True"
                          IsReadOnly="True"
                          RowHeight="{StaticResource DataGridRowHeight}"
                          GridLinesVisibility="Horizontal"
                          FontSize="{StaticResource FontSizeBase}"
                          Background="{StaticResource SurfaceBrush}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="เลขที่เอกสาร"
                                            Binding="{Binding DocNo}"
                                            Width="170"/>

                        <DataGridTextColumn Header="รหัสสินค้า"
                                            Binding="{Binding ItemCode}"
                                            Width="*"/>

                        <DataGridTextColumn Header="จำนวน"
                                            Binding="{Binding Qty, StringFormat='{}{0:N2}'}"
                                            Width="120"/>

                        <DataGridTextColumn Header="หน่วย"
                                            Binding="{Binding UnitCode}"
                                            Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Row="0" Grid.RowSpan="5"
                IsVisible="{Binding IsLoading}"
                Background="#B3FFFFFF">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8">
                <ProgressBar IsIndeterminate="True"
                             Width="160"
                             Height="4"
                             Foreground="{StaticResource AccentBlueBrush}"/>
                <TextBlock Text="กำลังโหลด..."
                           FontSize="{StaticResource FontSizeSM}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
