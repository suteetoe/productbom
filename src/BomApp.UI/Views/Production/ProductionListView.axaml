<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BomApp.UI.ViewModels.Production"
             xmlns:contracts="using:BomApp.Shared.Contracts"
             x:Class="BomApp.UI.Views.Production.ProductionListView"
             x:DataType="vm:ProductionListViewModel">

    <Grid RowDefinitions="Auto,Auto,*"
          Background="{StaticResource SurfaceSecondaryBrush}">

        <TextBlock Grid.Row="0"
                   Text="รายการผลิต"
                   FontSize="{StaticResource FontSizeH2}"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimaryBrush}"
                   Margin="{StaticResource PanelPadding}"/>

        <Border Grid.Row="1"
                Margin="16,0,16,16"
                Padding="{StaticResource PanelPadding}"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource RadiusMD}">
            <Grid ColumnDefinitions="Auto,390,12,Auto,12,Auto,12,Auto,120"
                  VerticalAlignment="Top">
                <TextBlock Grid.Column="0"
                           Text="ข้อความค้นหา :"
                           FontSize="{StaticResource FontSizeBase}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>

                <TextBox Grid.Column="1"
                         Text="{Binding DocNoSearch, Mode=TwoWay}"
                         PlaceholderText="ค้นหาเลขที่เอกสาร"
                         Height="34"
                         CornerRadius="{StaticResource RadiusMD}"
                         FontSize="{StaticResource FontSizeBase}"/>

                <Button Grid.Column="3"
                        Content="ค้นหา"
                        Command="{Binding SearchCommand}"
                        MinWidth="96"
                        Height="34"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Background="{StaticResource AccentBlueBrush}"
                        Foreground="White"
                        CornerRadius="{StaticResource RadiusMD}"
                        FontSize="{StaticResource FontSizeBase}"/>

                <Button Grid.Column="5"
                        Content="ลบ"
                        Command="{Binding DeleteDocumentCommand}"
                        CommandParameter="{Binding SelectedDocument}"
                        MinWidth="96"
                        Height="34"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Background="Transparent"
                        Foreground="{StaticResource DangerBrush}"
                        BorderBrush="{StaticResource DangerBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource RadiusMD}"
                        FontSize="{StaticResource FontSizeBase}"
                        IsEnabled="{Binding SelectedDocument, Converter={x:Static ObjectConverters.IsNotNull}}"/>

                <TextBlock Grid.Column="7"
                           Text="ต่อหน้า"
                           FontSize="{StaticResource FontSizeSM}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>

                <ComboBox Grid.Column="8"
                          ItemsSource="{Binding PageSizeOptions}"
                          SelectedItem="{Binding PageSize, Mode=TwoWay}"
                          Height="34"
                          CornerRadius="{StaticResource RadiusMD}"
                          FontSize="{StaticResource FontSizeBase}"/>
            </Grid>
        </Border>

        <Grid Grid.Row="2"
              ColumnDefinitions="0.9*,24,1.1*"
              Margin="16,0,16,16">

            <Border Grid.Column="0"
                    Grid.ColumnSpan="{Binding DocumentListColumnSpan}"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource RadiusMD}">
                <Grid RowDefinitions="*,Auto">
                    <DockPanel Grid.Row="0" LastChildFill="True">
                        <Border DockPanel.Dock="Top"
                                Background="{StaticResource SurfaceSecondaryBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="8,6">
                            <Grid ColumnDefinitions="160,*" ColumnSpacing="8">
                                <TextBlock Grid.Column="0" Text="&#x0E27;&#x0E31;&#x0E19;&#x0E17;&#x0E35;&#x0E48;" FontSize="{StaticResource FontSizeSM}" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Column="1" Text="&#x0E40;&#x0E25;&#x0E02;&#x0E17;&#x0E35;&#x0E48;&#x0E40;&#x0E2D;&#x0E01;&#x0E2A;&#x0E32;&#x0E23;" FontSize="{StaticResource FontSizeSM}" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </Grid>
                        </Border>

                        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Documents}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="contracts:BomProductionDto">
                                        <Button Command="{Binding ((vm:ProductionListViewModel)DataContext).SelectDocumentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Padding="0"
                                                HorizontalContentAlignment="Stretch">
                                            <Border BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="0,0,0,1"
                                                    Padding="8,5"
                                                    MinHeight="{StaticResource DataGridRowHeight}">
                                                <Grid ColumnDefinitions="160,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Text="{Binding DocDate, StringFormat='{}{0:dd/MM/yyyy}'}" FontSize="{StaticResource FontSizeBase}" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding DocNo}" FontSize="{StaticResource FontSizeBase}" Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>

                    <Border Grid.Row="1"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,1,0,0"
                            Padding="{StaticResource SpaceSM}">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0"
                                       Text="{Binding PageSummary}"
                                       FontSize="{StaticResource FontSizeSM}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        Spacing="8">
                                <Button Content="ก่อนหน้า"
                                        Command="{Binding PreviousPageCommand}"
                                        IsEnabled="{Binding CanGoPrevious}"
                                        FontSize="{StaticResource FontSizeSM}"
                                        CornerRadius="{StaticResource RadiusSM}"
                                        Padding="10,4"/>
                                <Button Content="ถัดไป"
                                        Command="{Binding NextPageCommand}"
                                        IsEnabled="{Binding CanGoNext}"
                                        FontSize="{StaticResource FontSizeSM}"
                                        CornerRadius="{StaticResource RadiusSM}"
                                        Padding="10,4"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource RadiusMD}"
                    Padding="{StaticResource PanelPadding}"
                    IsVisible="{Binding SelectedDocument, Converter={x:Static ObjectConverters.IsNotNull}}">
            <Grid RowDefinitions="Auto,8,Auto,8,Auto,20,*,20,*">

                <Grid Grid.Row="0"
                      ColumnDefinitions="116,108,*">
                    <TextBlock Grid.Column="0"
                               Text="วันที่เอกสาร :"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               FontSize="{StaticResource FontSizeBase}"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <Border Grid.Column="1"
                            Height="28"
                            Background="{StaticResource SurfaceSecondaryBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource RadiusSM}">
                        <TextBlock Text="{Binding SelectedDocument.DocDate, StringFormat='{}{0:dd/MM/yyyy}'}"
                                   VerticalAlignment="Center"
                                   Margin="8,0"
                                   FontSize="{StaticResource FontSizeBase}"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                    </Border>
                </Grid>

                <Grid Grid.Row="2"
                      ColumnDefinitions="116,*,126">
                    <TextBlock Grid.Column="0"
                               Text="เลขที่เอกสาร :"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               FontSize="{StaticResource FontSizeBase}"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <Border Grid.Column="1"
                            Height="28"
                            Background="{StaticResource SurfaceSecondaryBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource RadiusSM}">
                        <TextBlock Text="{Binding SelectedDocument.DocNo}"
                                   VerticalAlignment="Center"
                                   Margin="8,0"
                                   FontSize="{StaticResource FontSizeBase}"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                    </Border>
                </Grid>

                <Grid Grid.Row="4"
                      ColumnDefinitions="116,*">
                    <TextBlock Grid.Column="0"
                               Text="หมายเหตุ :"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Top"
                               Margin="0,8,8,0"
                               FontSize="{StaticResource FontSizeBase}"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <Border Grid.Column="1"
                            Height="66"
                            Background="{StaticResource SurfaceSecondaryBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource RadiusSM}"/>
                </Grid>

                <Grid Grid.Row="6"
                      RowDefinitions="Auto,*">
                    <TextBlock Grid.Row="0"
                               Text="รายการสินค้าที่ผลิต"
                               FontSize="{StaticResource FontSizeBase}"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,6"/>
                    <Border Grid.Row="1"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource RadiusSM}"
                            Background="{StaticResource SurfaceBrush}"
                            MinHeight="145">
                        <DockPanel LastChildFill="True">
                            <Border DockPanel.Dock="Top"
                                    Background="{StaticResource SurfaceSecondaryBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="0,0,0,1"
                                    Padding="8,6">
                                <Grid ColumnDefinitions="150,150,120,*,120,120,100" ColumnSpacing="8">
                                    <TextBlock Grid.Column="0" Text="&#x0E23;&#x0E2B;&#x0E31;&#x0E2A;&#x0E2A;&#x0E34;&#x0E19;&#x0E04;&#x0E49;&#x0E32;" FontSize="{StaticResource FontSizeSM}" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="1" Text="&#x0E1A;&#x0E34;&#x0E25;&#x0E02;&#x0E32;&#x0E22;" FontSize="{StaticResource FontSizeSM}" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="2" Text="&#x0E27;&#x0E31;&#x0E19;&#x0E17;&#x0E35;&#x0E48;&#x0E1A;&#x0E34;&#x0E25;" FontSize="{StaticResource FontSizeSM}" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="3" Text="&#x0E0A;&#x0E37;&#x0E48;&#x0E2D;&#x0E2A;&#x0E34;&#x0E19;&#x0E04;&#x0E49;&#x0E32;" FontSize="{StaticResource FontSizeSM}" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="4" Text="&#x0E2B;&#x0E19;&#x0E48;&#x0E27;&#x0E22;&#x0E19;&#x0E31;&#x0E1A;" FontSize="{StaticResource FontSizeSM}" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="5" Text="&#x0E08;&#x0E33;&#x0E19;&#x0E27;&#x0E19;" FontSize="{StaticResource FontSizeSM}" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="6" Text="&#x0E2A;&#x0E39;&#x0E15;&#x0E23;" FontSize="{StaticResource FontSizeSM}" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </Grid>
                            </Border>

                            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding SelectedDocumentDetails}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="contracts:BomProductionOrderDto">
                                            <Border BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="0,0,0,1"
                                                    Padding="8,5"
                                                    MinHeight="{StaticResource DataGridRowHeight}">
                                                <Grid ColumnDefinitions="150,150,120,*,120,120,100" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Text="{Binding ItemCode}" FontSize="{StaticResource FontSizeBase}" Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding RefDocNo}" FontSize="{StaticResource FontSizeBase}" Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding RefDocDate, StringFormat='{}{0:dd/MM/yyyy}'}" FontSize="{StaticResource FontSizeBase}" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="3" FontSize="{StaticResource FontSizeBase}" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="4" Text="{Binding UnitCode}" FontSize="{StaticResource FontSizeBase}" Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="5" Text="{Binding Qty, StringFormat='{}{0:N2}'}" FontSize="{StaticResource FontSizeBase}" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="6" FontSize="{StaticResource FontSizeBase}" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                </Grid>

                <Grid Grid.Row="8"
                      RowDefinitions="Auto,*">
                    <TextBlock Grid.Row="0"
                               Text="วัตถุดิบที่ใช้ไป"
                               FontSize="{StaticResource FontSizeBase}"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,6"/>
                    <Border Grid.Row="1"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource RadiusSM}"
                            Background="{StaticResource SurfaceBrush}"
                            MinHeight="230">
                        <DockPanel LastChildFill="True">
                            <Border DockPanel.Dock="Top"
                                    Background="{StaticResource SurfaceSecondaryBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="0,0,0,1"
                                    Padding="8,6">
                                <Grid ColumnDefinitions="150,*,120,120" ColumnSpacing="8">
                                    <TextBlock Grid.Column="0" Text="&#x0E23;&#x0E2B;&#x0E31;&#x0E2A;&#x0E2A;&#x0E34;&#x0E19;&#x0E04;&#x0E49;&#x0E32;" FontSize="{StaticResource FontSizeSM}" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="1" Text="&#x0E0A;&#x0E37;&#x0E48;&#x0E2D;&#x0E2A;&#x0E34;&#x0E19;&#x0E04;&#x0E49;&#x0E32;" FontSize="{StaticResource FontSizeSM}" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="2" Text="&#x0E2B;&#x0E19;&#x0E48;&#x0E27;&#x0E22;&#x0E19;&#x0E31;&#x0E1A;" FontSize="{StaticResource FontSizeSM}" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="3" Text="&#x0E08;&#x0E33;&#x0E19;&#x0E27;&#x0E19;" FontSize="{StaticResource FontSizeSM}" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </Grid>
                            </Border>

                            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding MaterialUsageRows}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="contracts:BomProductionDetailDto">
                                            <Border BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="0,0,0,1"
                                                    Padding="8,5"
                                                    MinHeight="{StaticResource DataGridRowHeight}">
                                                <Grid ColumnDefinitions="150,*,120,120" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Text="{Binding ItemCode}" FontSize="{StaticResource FontSizeBase}" Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding ItemName}" FontSize="{StaticResource FontSizeBase}" Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding UnitCode}" FontSize="{StaticResource FontSizeBase}" Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="3" Text="{Binding Qty, StringFormat='{}{0:N2}'}" FontSize="{StaticResource FontSizeBase}" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                </Grid>
            </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="0" Grid.RowSpan="3"
                IsVisible="{Binding IsLoading}"
                Background="#B3FFFFFF">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8">
                <ProgressBar IsIndeterminate="True"
                             Width="160"
                             Height="4"
                             Foreground="{StaticResource AccentBlueBrush}"/>
                <TextBlock Text="กำลังโหลด..."
                           FontSize="{StaticResource FontSizeSM}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource DangerBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource RadiusSM}"
                Padding="{StaticResource SpaceSM}"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,50,0,0"
                IsVisible="{Binding HasError}">
            <TextBlock Text="{Binding ErrorMessage}"
                       FontSize="{StaticResource FontSizeSM}"
                       Foreground="{StaticResource DangerBrush}"
                       TextWrapping="Wrap"/>
        </Border>
    </Grid>
</UserControl>
