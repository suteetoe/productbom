<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:BomApp.UI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="BomApp.UI.Views.LoginView"
        x:DataType="vm:LoginViewModel"
        Icon="avares://BomApp.UI/Assets/icons8-product-documents-48.ico"
        Title="Smart BOM — เข้าสู่ระบบ"
        Width="420"
        Height="480"
        MinWidth="420"
        MinHeight="480"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource SurfaceSecondaryBrush}">

    <!--
        DataContext is assigned at runtime in App.axaml.cs.
        No Design.DataContext — LoginViewModel requires INavigationService.
    -->

    <Grid>
        <Button Command="{Binding OpenSettingsCommand}"
                Width="44"
                Height="44"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Margin="{StaticResource SpaceLG}"
                CornerRadius="{StaticResource RadiusMD}"
                Background="{StaticResource SurfaceBrush}"
                Foreground="{StaticResource TextSecondaryBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                ToolTip.Tip="ตั้งค่า">
            <TextBlock Text="⚙"
                       FontSize="20"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Button>

        <!-- Outer centering container -->
        <Grid HorizontalAlignment="Center" VerticalAlignment="Center">

        <!-- Card panel -->
        <Border Background="{StaticResource SurfaceBrush}"
                CornerRadius="{StaticResource RadiusLG}"
                Padding="{StaticResource CardPadding}"
                Width="380"
                BoxShadow="0 4 16 0 #1A000000">

            <StackPanel Spacing="0">

                <!-- ================================================ -->
                <!-- Title block                                        -->
                <!-- ================================================ -->
                <StackPanel HorizontalAlignment="Center"
                            Margin="{StaticResource SpaceLG}">

                    <TextBlock Text="Smart BOM"
                               FontSize="{StaticResource FontSizeH1}"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap"
                               TextAlignment="Center"/>

                    <TextBlock Text="เข้าสู่ระบบ"
                               FontSize="{StaticResource FontSizeLG}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="{StaticResource SpaceXS}"/>
                </StackPanel>

                <!-- ================================================ -->
                <!-- Login-failed banner (full-width red banner)       -->
                <!-- ================================================ -->
                <Border Background="#FFEAEA"
                        CornerRadius="{StaticResource RadiusMD}"
                        Padding="{StaticResource SpaceSM}"
                        Margin="0,0,0,12"
                        IsVisible="{Binding HasError}">
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="{StaticResource DangerBrush}"
                               FontSize="{StaticResource FontSizeSM}"
                               TextWrapping="Wrap"/>
                </Border>

                <!-- ================================================ -->
                <!-- Form fields                                        -->
                <!-- ================================================ -->
                <StackPanel Spacing="16">

                    <!-- Username -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="ชื่อผู้ใช้"
                                   FontSize="{StaticResource FontSizeBase}"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBox Text="{Binding Username, Mode=TwoWay}"
                                 PlaceholderText="กรอกชื่อผู้ใช้"
                                 CornerRadius="{StaticResource RadiusMD}"
                                 FontSize="{StaticResource FontSizeBase}"/>
                    </StackPanel>

                    <!-- Password -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="รหัสผ่าน"
                                   FontSize="{StaticResource FontSizeBase}"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBox Text="{Binding Password, Mode=TwoWay}"
                                 PlaceholderText="กรอกรหัสผ่าน"
                                 PasswordChar="•"
                                 CornerRadius="{StaticResource RadiusMD}"
                                 FontSize="{StaticResource FontSizeBase}"/>
                    </StackPanel>

                    <!-- Login button -->
                    <Button Content="เข้าสู่ระบบ"
                            Command="{Binding LoginCommand}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            FontSize="{StaticResource FontSizeLG}"
                            FontWeight="SemiBold"
                            Padding="{StaticResource SpaceSM}"
                            CornerRadius="{StaticResource RadiusMD}"
                            Background="{StaticResource AccentBlueBrush}"
                            Foreground="White">
                        <Button.Styles>
                            <Style Selector="Button:pointerover /template/ ContentPresenter">
                                <Setter Property="Background" Value="{StaticResource AccentBlueDarkBrush}"/>
                            </Style>
                            <Style Selector="Button:disabled /template/ ContentPresenter">
                                <Setter Property="Opacity" Value="0.6"/>
                            </Style>
                        </Button.Styles>
                    </Button>

                    <!-- Loading indicator (visible while IsLoading) -->
                    <ProgressBar IsIndeterminate="True"
                                 IsVisible="{Binding IsLoading}"
                                 Height="4"
                                 Foreground="{StaticResource AccentBlueBrush}"/>

                </StackPanel>

                <!-- ================================================ -->
                <!-- Version footer                                     -->
                <!-- ================================================ -->
                <TextBlock Text="v1.0.0"
                           FontSize="{StaticResource FontSizeXS}"
                           Foreground="{StaticResource TextMutedBrush}"
                           HorizontalAlignment="Center"
                           Margin="{StaticResource SpaceXL}"/>

            </StackPanel>
        </Border>
        </Grid>
    </Grid>
</Window>
