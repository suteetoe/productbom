<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="Smart BOM"
    Manufacturer="Smart BOM Team"
    Version="$(var.ProductVersion)"
    UpgradeCode="1cc8719f-4874-4144-a4e9-317f50735d4f"
    Scope="perMachine">

    <SummaryInformation Description="Smart BOM installer" />
    <MajorUpgrade DowngradeErrorMessage="A newer version of Smart BOM is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Icon Id="AppIcon.ico" SourceFile="$(var.RepoRoot)src\BomApp.UI\Assets\avalonia-logo.ico" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon.ico" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="CompanyFolder" Name="Smart BOM Team">
        <Directory Id="INSTALLFOLDER" Name="Smart BOM">
          <Directory Id="CLIFOLDER" Name="Cli" />
        </Directory>
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="Smart BOM" />
    </StandardDirectory>

    <Feature Id="MainFeature" Title="Smart BOM" Level="1">
      <ComponentGroupRef Id="ApplicationPayload" />
      <ComponentGroupRef Id="CliPayload" />
      <ComponentRef Id="ApplicationShortcutComponent" />
      <ComponentRef Id="CliPathComponent" />
    </Feature>

    <ComponentGroup Id="ApplicationPayload" Directory="INSTALLFOLDER">
      <Files Include="$(var.PublishDir)**">
        <Exclude Files="$(var.PublishDir)**\*.pdb" />
        <Exclude Files="$(var.PublishDir)**\*.xml" />
      </Files>
    </ComponentGroup>

    <ComponentGroup Id="CliPayload" Directory="CLIFOLDER">
      <Files Include="$(var.CliPublishDir)**">
        <Exclude Files="$(var.CliPublishDir)**\*.pdb" />
        <Exclude Files="$(var.CliPublishDir)**\*.xml" />
      </Files>
    </ComponentGroup>

    <Component Id="ApplicationShortcutComponent" Directory="ApplicationProgramsFolder" Guid="f3a4a534-a090-42c9-ae1c-70083b07be99">
      <Shortcut
        Id="ApplicationStartMenuShortcut"
        Name="Smart BOM"
        Description="Open Smart BOM"
        Target="[INSTALLFOLDER]BomApp.UI.exe"
        WorkingDirectory="INSTALLFOLDER" />
      <RemoveFolder Id="RemoveApplicationProgramsFolder" On="uninstall" />
      <RegistryValue
        Root="HKCU"
        Key="Software\Smart BOM"
        Name="Installed"
        Type="integer"
        Value="1"
        KeyPath="yes" />
    </Component>

    <Component Id="CliPathComponent" Directory="CLIFOLDER" Guid="9e47c447-3a48-419b-a35e-4a3e91ff0ed1">
      <Environment
        Id="CliPath"
        Name="PATH"
        Value="[CLIFOLDER]"
        Action="set"
        Part="last"
        System="yes" />
      <RegistryValue
        Root="HKLM"
        Key="Software\Smart BOM"
        Name="CliPathConfigured"
        Type="integer"
        Value="1"
        KeyPath="yes" />
    </Component>
  </Package>
</Wix>
